import heapq

def minCostConnectPoints(points):
    n = len(points)
    visited = [False]*n
    minHeap = [(0, 0)]
    result = 0
    edges = 0

    while edges < n:
        cost, i = heapq.heappop(minHeap)
        if visited[i]:
            continue

        visited[i] = True
        result += cost
        edges += 1

        for j in range(n):
            if not visited[j]:
                dist = abs(points[i][0]-points[j][0]) + abs(points[i][1]-points[j][1])
                heapq.heappush(minHeap, (dist, j))

    return result


points = [[0,0],[2,2],[3,10],[5,2],[7,0]]
print(minCostConnectPoints(points))
