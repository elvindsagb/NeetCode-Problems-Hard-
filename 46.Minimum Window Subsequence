Concept: DP + Two Pointers

Problem:
Find the smallest substring in s that contains t as a subsequence.

----------------------------------------------------------------------------------------------------------------

def minWindow(s, t):
    m, n = len(s), len(t)
    dp = [[-1]*(n+1) for _ in range(m+1)]

    for i in range(m+1):
        dp[i][0] = i

    for i in range(1, m+1):
        for j in range(1, n+1):
            if s[i-1] == t[j-1]:
                dp[i][j] = dp[i-1][j-1]
            else:
                dp[i][j] = dp[i-1][j]

    start, length = 0, float('inf')
    for i in range(1, m+1):
        if dp[i][n] != -1:
            if i - dp[i][n] < length:
                start = dp[i][n]
                length = i - dp[i][n]

    return "" if length == float('inf') else s[start:start+length]
