Concept: Interval DP (like Matrix Chain Multiplication)

Problem:
Minimize cost of cutting a stick at given positions.

-----------------------------------------------------------------------------------------------------

def minCost(n, cuts):
    cuts = sorted([0] + cuts + [n])
    m = len(cuts)

    dp = [[0]*m for _ in range(m)]

    for length in range(2, m):
        for i in range(m - length):
            j = i + length
            dp[i][j] = float('inf')
            for k in range(i+1, j):
                dp[i][j] = min(dp[i][j],
                               dp[i][k] + dp[k][j] + cuts[j] - cuts[i])

    return dp[0][m-1]
