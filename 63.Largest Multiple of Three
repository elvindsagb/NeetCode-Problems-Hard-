Concept: Greedy + Digit Counting

Problem:
Form largest number divisible by 3 using given digits.

---------------------------------------------------------------------------------------------

def largestMultipleOfThree(digits):
    digits.sort()
    total = sum(digits)

    mod1, mod2 = [], []

    for d in digits:
        if d % 3 == 1:
            mod1.append(d)
        elif d % 3 == 2:
            mod2.append(d)

    def remove(arr, count):
        for _ in range(count):
            if arr:
                digits.remove(arr.pop(0))
            else:
                return False
        return True

    if total % 3 == 1:
        if not remove(mod1, 1):
            remove(mod2, 2)
    elif total % 3 == 2:
        if not remove(mod2, 1):
            remove(mod1, 2)

    if not digits:
        return ""

    digits.sort(reverse=True)
    if digits[0] == 0:
        return "0"

    return "".join(map(str, digits))
