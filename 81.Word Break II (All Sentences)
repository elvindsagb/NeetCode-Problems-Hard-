Return all possible sentences, not just True/False.

------------------------------------------------------------------------------------------------------

def wordBreak(s, wordDict):
    wordSet = set(wordDict)
    memo = {}

    def backtrack(start):
        if start in memo:
            return memo[start]

        if start == len(s):
            return [""]

        res = []
        for end in range(start+1, len(s)+1):
            word = s[start:end]
            if word in wordSet:
                for sub in backtrack(end):
                    res.append(word + (" " + sub if sub else ""))

        memo[start] = res
        return res

    return backtrack(0)


print(wordBreak("catsanddog", ["cat","cats","and","sand","dog"]))
