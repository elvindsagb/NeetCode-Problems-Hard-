Concept: Binary Search + Rolling Hash (Rabin-Karp)

Problem:
Find longest substring that appears at least twice.


-----------------------------------------------------------------------------------------

def longestDupSubstring(s):
    n = len(s)
    nums = [ord(c) - ord('a') for c in s]
    mod = 2**63 - 1

    def search(L):
        h = 0
        base = 26
        power = pow(base, L, mod)

        seen = set()

        for i in range(n):
            h = (h * base + nums[i]) % mod
            if i >= L:
                h = (h - nums[i-L] * power) % mod
            if i >= L-1:
                if h in seen:
                    return i - L + 1
                seen.add(h)
        return -1

    left, right = 1, n
    start = 0

    while left <= right:
        mid = (left + right) // 2
        idx = search(mid)
        if idx != -1:
            start = idx
            left = mid + 1
        else:
            right = mid - 1

    return s[start:start + left - 1]
