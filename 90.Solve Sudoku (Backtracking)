Problem:
Solve a 9×9 Sudoku board.

Concepts: Backtracking + Constraint Checking

-------------------------------------------------------------------------

def is_valid(board, r, c, val):
    for i in range(9):
        if board[r][i] == val or board[i][c] == val:
            return False

    br, bc = (r//3)*3, (c//3)*3
    for i in range(br, br+3):
        for j in range(bc, bc+3):
            if board[i][j] == val:
                return False
    return True

def solve(board):
    for i in range(9):
        for j in range(9):
            if board[i][j] == ".":
                for num in "123456789":
                    if is_valid(board, i, j, num):
                        board[i][j] = num
                        if solve(board):
                            return True
                        board[i][j] = "."
                return False
    return True
