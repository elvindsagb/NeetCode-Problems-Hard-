Concept: DP + Bitmask (Row-wise optimization)

Problem:
Max students seated without cheating.

-------------------------------------------------------------------------------------------------------

def maxStudents(seats):
    rows, cols = len(seats), len(seats[0])
    dp = {}

    def valid(mask, row):
        for j in range(cols):
            if (mask & (1 << j)):
                if seats[row][j] == '#':
                    return False
                if j > 0 and (mask & (1 << (j-1))):
                    return False
        return True

    def dfs(row, prev_mask):
        if row == rows:
            return 0

        key = (row, prev_mask)
        if key in dp:
            return dp[key]

        res = 0
        for mask in range(1 << cols):
            if not valid(mask, row):
                continue
            if mask & (prev_mask << 1) or mask & (prev_mask >> 1):
                continue

            res = max(res, bin(mask).count('1') + dfs(row+1, mask))

        dp[key] = res
        return res

    return dfs(0, 0)
