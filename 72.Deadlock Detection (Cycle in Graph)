def detect_deadlock(graph):
    visited = set()
    rec_stack = set()

    def dfs(node):
        if node in rec_stack:
            return True
        if node in visited:
            return False

        visited.add(node)
        rec_stack.add(node)

        for neighbor in graph.get(node, []):
            if dfs(neighbor):
                return True

        rec_stack.remove(node)
        return False

    for node in graph:
        if dfs(node):
            return True
    return False


# Example
graph = {
    "P1": ["R1"],
    "R1": ["P2"],
    "P2": ["R2"],
    "R2": ["P1"]
}

print("Deadlock detected" if detect_deadlock(graph) else "No deadlock")
