Concept: BFS + Bitmask (State Compression)

Problem:
Given a graph, find the shortest path that visits all nodes.

-------------------------------------------------------------------------------------------------------------

from collections import deque

def shortestPathLength(graph):
    n = len(graph)
    queue = deque()
    visited = set()

    for i in range(n):
        queue.append((i, 1 << i))
        visited.add((i, 1 << i))

    steps = 0
    final_mask = (1 << n) - 1

    while queue:
        for _ in range(len(queue)):
            node, mask = queue.popleft()

            if mask == final_mask:
                return steps

            for nei in graph[node]:
                new_mask = mask | (1 << nei)
                if (nei, new_mask) not in visited:
                    visited.add((nei, new_mask))
                    queue.append((nei, new_mask))
        steps += 1
        
